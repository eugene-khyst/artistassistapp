{
  "name": "artistassistapp",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "lingui:extract": "lingui extract --clean",
    "translate": "tsx translate-po.ts",
    "cf-typegen": "wrangler types --path='./functions/types.d.ts'",
    "dev": "vite",
    "build": "npm run cf-typegen && tsc -b && BUILD_ID=$(date +%s) vite build",
    "preview": "vite preview",
    "build:local-dev": "npm run build -- --mode local-dev",
    "clean": "rm -rf node_modules/.vite dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "type-check": "tsc --noEmit",
    "test": "npm run type-check && npm run lint && npm run format",
    "prepare": "husky"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@fontsource/kalam": "^5.2.8",
    "@lingui/react": "^5.9.5",
    "@tanstack/react-query": "^5.100.14",
    "@yudiel/react-qr-scanner": "^2.6.0",
    "antd": "^6.4.3",
    "clsx": "^2.1.1",
    "comlink": "^4.4.2",
    "dayjs": "^1.11.21",
    "file-saver": "^2.0.5",
    "html-to-image": "^1.11.13",
    "idb": "^8.0.3",
    "jose": "^6.2.3",
    "mime": "^4.1.0",
    "onnxruntime-web": "^1.26.0",
    "print-js": "^1.6.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-compare-slider": "^3.1.0",
    "react-dom": "^19.2.6",
    "react-dropzone": "^15.0.0",
    "react-error-boundary": "^6.1.2",
    "react-sticky-box": "^2.0.5",
    "react-string-replace": "^2.0.1",
    "react-to-print": "^3.3.0",
    "whatwg-mimetype": "^5.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/config-helpers": "^0.6.0",
    "@eslint/js": "^9.39.4",
    "@lingui/swc-plugin": "^5.11.0",
    "@lingui/vite-plugin": "^5.9.5",
    "@types/file-saver": "^2.0.7",
    "@types/gettext-parser": "^9.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/whatwg-mimetype": "^5.0.0",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "bing-translate-api": "^4.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-license-header": "^0.9.0",
    "eslint-plugin-lingui": "^0.13.1",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "gettext-parser": "^9.0.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsc-files": "^1.1.4",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3",
    "vite-plugin-glsl": "^1.6.0",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-svgr": "^4.5.0",
    "wrangler": "^4.95.0"
  },
  "lint-staged": {
    "**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{ts,tsx}": [
      "sh -c 'tsc-files --noEmit $(ls -d ./**/* | grep .d.ts) $0 $@'",
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{css,html}": "prettier --write"
  },
  "license": "AGPL-3.0-only"
}
